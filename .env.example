# ── Required for both debug CLI and Telegram bot ──────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_KEEP_ALIVE=30m
VISION_MODEL=qwen3-vl:2b-instruct
CHEF_MODEL=ministral-3:3b
DB_PATH=./fridgesurfer.db
RECENT_RECIPES_N=5

# ── Required for Telegram bot only (not needed for debug_cli.py) ───────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_CHAT_ID=your_chat_id
SCHEDULED_SCAN_TIME=17:00

# ── Camera (Jetson only; not needed for debug_cli.py) ─────────────────────────
# Set to an integer index (e.g. 0) for USB camera, or a GStreamer pipeline string for CSI.
CAMERA_INDEX=0
